# Pacioli — environment variable reference
# Copy this file to .env and fill in values before running.

# Required
GOOGLE_API_KEY=your-google-api-key-here

# Optional — all have sensible defaults
APP_PASSWORD=            # If set, all /api/* requests must include this as X-API-Key header
AI_MODEL=gemini-3.1-flash-lite
AI_TEMPERATURE=0.2
AI_TIMEOUT=45            # Seconds before the AI call is aborted
MAX_RETRIES=2
MAX_INPUT_LENGTH=500     # Max user message length (chars)
CHAT_RATE_LIMIT=10/minute  # Rate limit for /api/chat (slowapi format)
PROPOSAL_TIMEOUT_MINUTES=15  # Auto-reject pending proposals after this many minutes

LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR

LEDGER_PATH=data/ledger.xlsx
LEDGER_TEMPLATE_PATH=data/ledger.template.xlsx
DB_PATH=data/accountant.db

TAX_RATE=0.0             # Sales/VAT rate as decimal (e.g. 0.1 for 10%)
FISCAL_YEAR=2026         # Transactions outside this year trigger a warning
