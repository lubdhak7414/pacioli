# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# ── Virtual environments ──────────────────────────────────
.venv/
venv/
env/

# ── Secrets / environment ─────────────────────────────────
.env
*.env
!.env.example

# ── Runtime data (regenerated on startup) ─────────────────
# The live ledger holds real financial data and is seeded from
# data/ledger.template.xlsx on first run — never commit the live copy.
data/ledger.xlsx
data/accountant.db
data/accountant.db-wal
data/accountant.db-shm
data/*.lock
data/ledger.xlsx.lock
data/backups/
data/ledger_backup_*.xlsx
data/ledger.xlsx.bak*

# ── Tooling caches ────────────────────────────────────────
.ruff_cache/
.mypy_cache/
.pytest_cache/

# ── Editor / OS ───────────────────────────────────────────
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# ── Local-only notes (never published) ────────────────────
Details.md
